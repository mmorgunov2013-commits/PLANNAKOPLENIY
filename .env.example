# Публичный URL сайта (canonical, OG). Локально можно не задавать.
# GitHub Pages: https://mmorgunov2013-commits.github.io/PLANNAKOPLENIY
NEXT_PUBLIC_SITE_URL=https://вашсайт.ru

# Яндекс.Метрика — номер счётчика ДОЛЖЕН совпадать с id в URL кабинета (…/dashboard?id=…).
# Если смотришь отчёты другого счётчика — визиты «не видны». Сборка GitHub: задай Variable.
# NEXT_PUBLIC_YM_ID=108609817

# Только для сборки под GitHub Pages (репозиторий /PLANNAKOPLENIY). Локально не задавать.
# NEXT_PUBLIC_BASE_PATH=/PLANNAKOPLENIY

# Публичная ссылка оплаты (например, ссылка от T-Bank "Оплата по ссылке")
# Пока ссылка не готова, можно оставить пусто — тогда /oplata покажет статус ожидания.
NEXT_PUBLIC_PAYMENT_URL=

# URL бэкенда оплаты (без слэша в конце), например https://plan-nakopleniy.ru или https://xxx.onrender.com
# GitHub: Settings → Actions → Variables
NEXT_PUBLIC_PAYMENT_API_URL=

# Путь Init: на Reg.ru PHP — /api/tbank_init.php ; на старом Node на Render — /payments/tbank/init
NEXT_PUBLIC_PAYMENT_INIT_PATH=/api/tbank_init.php

# Куда редиректит /oplata на лендинге (страница оплаты на plan-nakopleniy.ru)
NEXT_PUBLIC_PAYMENT_PAGE_URL=https://plan-nakopleniy.ru/oplata/
